---
import "../styles/global.css";
import { SITE } from "../site-config";

const {
  title = SITE.name,
  description = "Portfolio site",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.domain).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>

  <body class="bg-slate-950 text-slate-200 selection:bg-blue-500 selection:text-white antialiased">
    <!-- Interactive dot field -->
    <canvas id="dotField" aria-hidden="true"></canvas>

    <slot />

    <script is:inline>
      const reduce =
        window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce) {
        // no animation
      } else {
        const canvas = document.getElementById("dotField");
        if (!(canvas instanceof HTMLCanvasElement)) return;
        const ctx = canvas.getContext("2d", { alpha: true });
        if (!ctx) return;

        const dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));

        let w = 0;
        let h = 0;

        // Mouse target
        let mx = -9999;
        let my = -9999;

        // Grid config (subtle)
        const spacing = 34;               // distance between dots
        const baseRadius = 1.15;          // dot size
        const influenceRadius = 170;      // how far the mouse affects dots
        const pullStrength = 0.10;        // how much dots move toward mouse
        const returnStrength = 0.06;      // how fast dots return to grid

        // Dot storage
        let dots = [];

        const resize = () => {
          w = window.innerWidth;
          h = window.innerHeight;

          canvas.width = Math.floor(w * dpr);
          canvas.height = Math.floor(h * dpr);
          canvas.style.width = w + "px";
          canvas.style.height = h + "px";

          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

          // Build dot grid
          dots = [];
          const cols = Math.ceil(w / spacing) + 2;
          const rows = Math.ceil(h / spacing) + 2;

          for (let y = 0; y < rows; y++) {
            for (let x = 0; x < cols; x++) {
              const gx = x * spacing;
              const gy = y * spacing;
              dots.push({
                gx, gy,     // grid position
                x: gx, y: gy // current position
              });
            }
          }
        };

        const onMove = (e) => {
          mx = e.clientX;
          my = e.clientY;
        };

        window.addEventListener("mousemove", onMove, { passive: true });
        window.addEventListener("resize", resize, { passive: true });

        resize();

        const draw = () => {
          ctx.clearRect(0, 0, w, h);

          // Base color is very faint, brighter near mouse
          // Keep it subtle: low alpha
          for (const d of dots) {
            const dx = mx - d.x;
            const dy = my - d.y;
            const dist = Math.hypot(dx, dy);

            // Attraction (only within radius)
            if (dist < influenceRadius) {
              const t = 1 - dist / influenceRadius; // 0..1
              // Pull toward mouse
              d.x += dx * pullStrength * t;
              d.y += dy * pullStrength * t;

              // Brightness increases slightly
              const alpha = 0.06 + 0.12 * t; // subtle
              ctx.fillStyle = `rgba(148, 163, 184, ${alpha.toFixed(3)})`;
              const r = baseRadius + 0.35 * t;

              ctx.beginPath();
              ctx.arc(d.x, d.y, r, 0, Math.PI * 2);
              ctx.fill();
            } else {
              // Return to grid slowly
              d.x += (d.gx - d.x) * returnStrength;
              d.y += (d.gy - d.y) * returnStrength;

              ctx.fillStyle = "rgba(148, 163, 184, 0.045)";
              ctx.beginPath();
              ctx.arc(d.x, d.y, baseRadius, 0, Math.PI * 2);
              ctx.fill();
            }
          }

          window.requestAnimationFrame(draw);
        };

        window.requestAnimationFrame(draw);
      }
    </script>
  </body>
</html>
