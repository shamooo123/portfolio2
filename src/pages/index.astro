---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Typewriter from "../components/Typewriter.astro";
import { getCollection } from "astro:content";
import { TYPEWRITER_WORDS, SOCIAL } from "../site-config";

const projects = (await getCollection("projects"))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const featured = [...projects.filter(p => p.data.featured), ...projects.filter(p => !p.data.featured)].slice(0, 4);
---

<BaseLayout
  title="Hishaam Ali Abbasi | Robotics Engineer and Developer"
  description="Robotics Engineering student at Queen Mary University of London. Control systems, embedded firmware, hardware integration, and rapid prototyping."
>
  <div class="fixed inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(56,189,248,0.03),transparent_50%)]"></div>
    <div class="absolute inset-0" style="background-image: radial-gradient(rgba(148, 163, 184, 0.05) 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <Nav />

  <main class="relative z-10">
    <section class="pt-32 pb-20 px-6 max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-2/3">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-bold tracking-wider text-blue-400 uppercase bg-blue-500/10 rounded-full border border-blue-500/20">
          <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
          Graduating 2026
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-4 leading-tight">
          Bridging software and <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-500 to-cyan-400">
            the physical world.
          </span>
        </h1>

        <div class="text-lg md:text-xl mb-6">
          <Typewriter prefix="I’m a" words={TYPEWRITER_WORDS} forceAnimate={true} />
        </div>

        <p class="text-lg text-slate-400 max-w-xl leading-relaxed mb-8">
          Hi, I’m Hishaam. I build robotics systems end to end, including mechanics, electronics, firmware, control, and software.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="#projects" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-all shadow-lg shadow-blue-500/20">
            See what I’ve built
          </a>
          <a href="/assets/Hishaam_Ali_Abbasi_CV.pdf" class="px-6 py-3 glass-panel hover:bg-white/5 text-white font-medium rounded-lg transition-all">
            Download CV
          </a>
          <a href="https://github.com/shamooo123" target="_blank" rel="noopener noreferrer" class="px-6 py-3 glass-panel hover:bg-white/5 text-white font-medium rounded-lg transition-all">
            GitHub
          </a>
          <a href="https://linkedin.com/in/hishaam-ali-abbasi" target="_blank" rel="noopener noreferrer" class="px-6 py-3 glass-panel hover:bg-white/5 text-white font-medium rounded-lg transition-all">
            LinkedIn
          </a>
        </div>
      </div>

      <div class="md:w-1/3 relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-500"></div>
        <div class="relative aspect-square rounded-2xl overflow-hidden glass-panel border border-white/10">
          <img src="/images/profile.jpg" alt="Hishaam Ali Abbasi" class="w-full h-full object-cover" />
        </div>
      </div>
    </section>

    <div class="w-full border-y border-white/5 bg-black/20 backdrop-blur-sm py-6 overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 flex flex-wrap gap-x-12 gap-y-4 justify-center md:justify-start text-slate-500 font-mono text-sm font-semibold tracking-tight">
        <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">01.</span> Python and C++</span>
        <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">02.</span> SolidWorks and CAD</span>
        <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">03.</span> ROS2 and Embedded</span>
        <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">04.</span> Web Development</span>
        <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">05.</span> Additive Manufacturing</span>
      </div>
    </div>

    <section id="about" class="py-20 px-6 max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl font-bold text-white mb-6">A hands on approach.</h2>
          <p class="text-slate-400 mb-4 leading-relaxed">
            My approach to engineering is practical. I enjoy the mathematical side of robotics, but I learn best by building, testing, and iterating.
          </p>
          <p class="text-slate-400 leading-relaxed mb-4">
            I treat my home setup as a rapid prototyping lab, and I have expanded my skillset beyond mechatronics into web development and e commerce.
          </p>
          <p class="text-slate-400 leading-relaxed border-l-2 border-blue-500 pl-4 italic">
            Outside the lab, I am an Explorer Scout Leader. Running weekly sessions and expeditions has built strong leadership and communication.
          </p>
        </div>

        <div class="glass-panel p-6 rounded-xl">
          <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider text-blue-400">Education</h3>
          <div class="space-y-4">
            <div>
              <div class="flex justify-between text-white font-medium">
                <span>BEng Robotics Engineering</span>
                <span>Graduating 2026</span>
              </div>
              <div class="text-slate-500 text-sm">Queen Mary University of London</div>
            </div>

            <div class="pt-4 border-t border-white/5">
              <div class="text-sm text-slate-400">Academic highlights:</div>
              <div class="flex flex-wrap gap-2 mt-2">
                <span class="px-2 py-1 bg-white/5 rounded text-xs text-slate-300">Numerical Methods and Data Science (86%)</span>
                <span class="px-2 py-1 bg-white/5 rounded text-xs text-slate-300">Control Systems and Analysis (78.9%)</span>
                <span class="px-2 py-1 bg-white/5 rounded text-xs text-slate-300">Modelling and Control (75.2%)</span>
              </div>

              <div class="mt-4 flex flex-wrap gap-3">
                <a href="/assets/HEAR_Hishaam_Ali_Abbasi.pdf" class="px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-xs font-medium text-white transition-all">
                  Download HEAR
                </a>
                <a href="/assets/Hishaam_Ali_Abbasi_CV.pdf" class="px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-xs font-medium text-white transition-all">
                  Download CV
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10 px-6 max-w-6xl mx-auto">
      <div class="glass-panel rounded-2xl border border-white/10 p-6 md:p-8">
        <h3 class="text-2xl font-bold text-white mb-2">Elsewhere</h3>
        <p class="text-slate-400 mb-5">
          YouTube has project videos. Instagram is professional and shows builds, progress, and behind the scenes.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={SOCIAL.youtube} target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white transition">
            YouTube
          </a>
          <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white transition">
            Instagram ({SOCIAL.instagramName})
          </a>
        </div>
      </div>
    </section>

    <section id="projects" class="py-24 px-6 max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="text-4xl font-bold text-white mb-2">Things I’ve built</h2>
          <p class="text-slate-400">Case studies with decisions, architecture, and outcomes.</p>
        </div>
        <a class="hidden md:inline-flex text-sm text-blue-400 hover:underline" href="/projects">View all case studies</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featured.map((p) => (
          <ProjectCard
            href={`/projects/${p.slug}`}
            title={p.data.title}
            subtitle={p.data.subtitle}
            image={p.data.heroImage}
            tags={p.data.tags}
            featured={p.data.featured}
          />
        ))}
      </div>

      <div class="mt-10 md:hidden">
        <a class="text-sm text-blue-400 hover:underline" href="/projects">View all case studies</a>
      </div>
    </section>

    <section id="experience" class="py-20 px-6 max-w-6xl mx-auto border-t border-white/5">
      <h2 class="text-3xl font-bold text-white mb-12">Work experience</h2>

      <div class="space-y-8">
        <div class="glass-panel p-8 rounded-2xl hover:bg-white/5 transition-colors">
          <div class="flex flex-col md:flex-row gap-6 md:gap-12">
            <div class="md:w-1/4">
              <div class="text-blue-400 font-mono text-sm mb-1 font-bold">Aug 2025</div>
              <div class="text-white text-lg font-bold">Alvis Robotics</div>
              <div class="text-slate-500 text-sm">Birmingham, UK</div>
            </div>
            <div class="md:w-3/4">
              <h3 class="text-xl font-bold text-white mb-2">Engineering Design and Research Intern (EOD Systems)</h3>
              <p class="text-slate-400 leading-relaxed mb-4">
                Worked with bomb disposal robots: firmware debugging, diagnosing physical failure points, and supporting upgrades to legacy platforms.
              </p>
            </div>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-2xl hover:bg-white/5 transition-colors">
          <div class="flex flex-col md:flex-row gap-6 md:gap-12">
            <div class="md:w-1/4">
              <div class="text-blue-400 font-mono text-sm mb-1 font-bold">Jul 2024</div>
              <div class="text-white text-lg font-bold">HSBC</div>
              <div class="text-slate-500 text-sm">London, UK</div>
            </div>
            <div class="md:w-3/4">
              <h3 class="text-xl font-bold text-white mb-2">Spring Insight Programme (Quant Stream)</h3>
              <p class="text-slate-400 leading-relaxed">
                Explored modelling workflows and data analysis in a large organisation.
              </p>
            </div>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-2xl hover:bg-white/5 transition-colors">
          <div class="flex flex-col md:flex-row gap-6 md:gap-12">
            <div class="md:w-1/4">
              <div class="text-blue-400 font-mono text-sm mb-1 font-bold">2021</div>
              <div class="text-white text-lg font-bold">AT Medics</div>
              <div class="text-slate-500 text-sm">London, UK</div>
            </div>
            <div class="md:w-3/4">
              <h3 class="text-xl font-bold text-white mb-2">Clinical Data Administrator</h3>
              <p class="text-slate-400 leading-relaxed">
                Managed clinical datasets and supported operational processes.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
