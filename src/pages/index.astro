---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Typewriter from "../components/Typewriter.astro";
import { SITE, SOCIAL, TYPEWRITER_WORDS } from "../site-config";

const gallery = [
  { src: "/images/project1.jpg", alt: "Fracture immobilisation trainer prototype" },
  { src: "/images/project2.jpg", alt: "BoxTurtle filament system / 3D printing setup" },
  { src: "/images/project3.jpg", alt: "Active camera gimbal prototype" },
  { src: "/images/project4.jpg", alt: "Formula Student suspension work" },
  { src: "/images/profile.jpg", alt: "Hishaam profile" },
];
---

<BaseLayout
  title="Hishaam Ali Abbasi | Robotics Engineer & Developer"
  description="Portfolio of Hishaam Ali Abbasi, a Robotics Engineer specializing in Control Systems, Hardware Integration, and Full-Stack Development."
>
  <Nav />

  <main class="relative z-10">
    <!-- Background -->
    <div class="fixed inset-0 z-0 pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(56,189,248,0.03),transparent_50%)]"></div>
      <div
        class="absolute inset-0"
        style="background-image: radial-gradient(rgba(148, 163, 184, 0.05) 1px, transparent 1px); background-size: 40px 40px;"
      ></div>
    </div>

    <!-- Hero -->
    <section class="relative z-10 pt-28 sm:pt-32 pb-16 sm:pb-20 px-4 sm:px-6 max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div class="reveal">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 mb-5 text-xs font-bold tracking-wider text-blue-400 uppercase bg-blue-500/10 rounded-full border border-blue-500/20"
          >
            <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
            Graduating 2026
          </div>

          <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-white mb-4 leading-tight">
            Bridging software and
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-500 to-cyan-400">
              the physical world.
            </span>
          </h1>

          <div class="text-lg sm:text-xl mb-5">
            <Typewriter prefix="I’m a" words={TYPEWRITER_WORDS} />
          </div>

          <p class="text-base sm:text-lg text-slate-400 max-w-xl leading-relaxed mb-7">
            Hi, I’m Hishaam. I build robotics systems end-to-end — mechanics, electronics, firmware, control, and
            software — and I love shipping real prototypes that move, sense, and interact.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 max-w-xl">
            <a
              href="/#projects"
              class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-all shadow-lg shadow-blue-500/20 text-center"
            >
              See what I’ve built
            </a>
            <a
              href="/assets/Hishaam_Ali_Abbasi_CV.pdf"
              class="px-6 py-3 glass-panel hover:bg-white/5 text-white font-semibold rounded-lg transition-all text-center border border-white/10"
            >
              Download CV
            </a>
            <a
              href={SOCIAL.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="px-6 py-3 glass-panel hover:bg-white/5 text-white font-medium rounded-lg transition-all text-center border border-white/10"
            >
              LinkedIn
            </a>
            <a
              href={SOCIAL.github}
              target="_blank"
              rel="noopener noreferrer"
              class="px-6 py-3 glass-panel hover:bg-white/5 text-white font-medium rounded-lg transition-all text-center border border-white/10"
            >
              GitHub
            </a>
          </div>
        </div>

        <div class="reveal md:justify-self-end">
          <div class="relative group max-w-[360px] mx-auto md:mx-0">
            <div class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-500"></div>
            <div class="relative aspect-square rounded-2xl overflow-hidden glass-panel border border-white/10">
              <img
                src="/images/profile.jpg"
                alt={SITE.name}
                class="w-full h-full object-cover"
                width="900"
                height="900"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills band (mobile scrollable) -->
    <div class="w-full border-y border-white/5 bg-black/20 backdrop-blur-sm py-5 overflow-hidden relative z-10">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex gap-x-10 gap-y-3 overflow-x-auto no-scrollbar text-slate-500 font-mono text-sm font-semibold tracking-tight">
          <span class="flex items-center gap-2 whitespace-nowrap hover:text-blue-400 transition-colors"><span class="text-blue-500">01.</span> Python / C++</span>
          <span class="flex items-center gap-2 whitespace-nowrap hover:text-blue-400 transition-colors"><span class="text-blue-500">02.</span> SolidWorks / CAD</span>
          <span class="flex items-center gap-2 whitespace-nowrap hover:text-blue-400 transition-colors"><span class="text-blue-500">03.</span> ROS2 & Embedded</span>
          <span class="flex items-center gap-2 whitespace-nowrap hover:text-blue-400 transition-colors"><span class="text-blue-500">04.</span> Web Dev</span>
          <span class="flex items-center gap-2 whitespace-nowrap hover:text-blue-400 transition-colors"><span class="text-blue-500">05.</span> Additive Mfg</span>
        </div>
      </div>
    </div>

    <!-- Snapshots -->
    <section class="py-16 sm:py-20 px-4 sm:px-6 max-w-6xl mx-auto relative z-10">
      <div class="flex items-end justify-between mb-8">
        <div class="reveal">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-2">Snapshots</h2>
          <p class="text-slate-400">Quick proof that I build real things — more media coming.</p>
        </div>
      </div>

      <!-- Mobile: horizontal scroll -->
      <div class="md:hidden flex gap-4 overflow-x-auto no-scrollbar pb-2">
        {gallery.map((g) => (
          <figure class="min-w-[75%] glass-panel rounded-2xl overflow-hidden border border-white/10">
            <img src={g.src} alt={g.alt} class="w-full h-56 object-cover" width="1200" height="700" loading="lazy" />
            <figcaption class="p-4 text-sm text-slate-400">{g.alt}</figcaption>
          </figure>
        ))}
      </div>

      <!-- Desktop: grid -->
      <div class="hidden md:grid grid-cols-12 gap-4">
        <figure class="col-span-7 glass-panel rounded-2xl overflow-hidden border border-white/10 reveal">
          <img src={gallery[0].src} alt={gallery[0].alt} class="w-full h-80 object-cover" width="1600" height="900" loading="lazy" />
          <figcaption class="p-4 text-sm text-slate-400">{gallery[0].alt}</figcaption>
        </figure>
        <div class="col-span-5 grid grid-rows-2 gap-4">
          <figure class="glass-panel rounded-2xl overflow-hidden border border-white/10 reveal">
            <img src={gallery[2].src} alt={gallery[2].alt} class="w-full h-40 object-cover" width="1600" height="900" loading="lazy" />
            <figcaption class="p-4 text-sm text-slate-400">{gallery[2].alt}</figcaption>
          </figure>
          <figure class="glass-panel rounded-2xl overflow-hidden border border-white/10 reveal">
            <img src={gallery[1].src} alt={gallery[1].alt} class="w-full h-40 object-cover" width="1600" height="900" loading="lazy" />
            <figcaption class="p-4 text-sm text-slate-400">{gallery[1].alt}</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- Social -->
    <section class="py-12 sm:py-16 px-4 sm:px-6 max-w-6xl mx-auto relative z-10">
      <div class="glass-panel rounded-2xl border border-white/10 p-6 sm:p-8 reveal">
        <h3 class="text-2xl font-bold text-white mb-2">More than a CV</h3>
        <p class="text-slate-400 mb-5">
          I keep my YouTube and Instagram professional — they’re where I share project videos, builds, and progress.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={SOCIAL.youtube} target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white transition">
            YouTube
          </a>
          <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white transition">
            Instagram
          </a>
        </div>
      </div>
    </section>

    <!-- Placeholder anchors (keep your existing sections below in your repo if you want) -->
    <section id="projects" class="py-10"></section>
    <section id="about" class="py-10"></section>
    <section id="experience" class="py-10"></section>

  </main>

  <Footer />

  <script>
    const reduceMotion =
      window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!reduceMotion) {
      const els = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("reveal-in");
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      els.forEach((el) => io.observe(el));
    } else {
      document.querySelectorAll(".reveal").forEach((el) => el.classList.add("reveal-in"));
    }
  </script>
</BaseLayout>
