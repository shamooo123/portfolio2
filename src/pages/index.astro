---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Typewriter from "../components/Typewriter.astro";
import { getCollection } from "astro:content";
import { FEATURED_YOUTUBE_VIDEOS, SOCIAL, SITE, TYPEWRITER_WORDS } from "../site-config";

const projects = (await getCollection("projects"))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const featured = [...projects.filter(p => p.data.featured), ...projects.filter(p => !p.data.featured)].slice(0, 4);

// Gallery: add your own images by dropping them into /public/images/gallery/
// then adding entries here.
const gallery: Array<{ src?: string; alt: string; caption: string; kind: 'image' | 'placeholder' }> = [
  { kind: 'image', src: '/images/project1.jpg', alt: 'Fracture immobilisation trainer prototype render', caption: 'Haptic medical trainer' },
  { kind: 'image', src: '/images/project2.jpg', alt: 'Filament handling / multi-material system', caption: 'Multi-material 3D printing' },
  { kind: 'image', src: '/images/project3.jpg', alt: 'DIY camera gimbal prototype', caption: 'Embedded control loops' },
  { kind: 'image', src: '/images/project4.jpg', alt: 'FEA / suspension design visual', caption: 'CAD + simulation work' },
  { kind: 'placeholder', alt: 'Add a workshop photo', caption: 'Add a workshop photo' },
  { kind: 'placeholder', alt: 'Add a demo screenshot', caption: 'Add a demo screenshot' },
];

const yt = FEATURED_YOUTUBE_VIDEOS;
---

<BaseLayout
  title="Hishaam Ali Abbasi | Robotics Engineering (QMUL) — Control, Embedded, Hardware"
  description="Robotics Engineering student at Queen Mary University of London. I build interactive physical systems — control, embedded firmware, sensing, and rapid prototyping."
>
  <div class="fixed inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(56,189,248,0.04),transparent_55%)]"></div>
    <div class="absolute inset-0" style="background-image: radial-gradient(rgba(148, 163, 184, 0.05) 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <a class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 bg-blue-600 text-white px-4 py-2 rounded" href="#main">
    Skip to content
  </a>

  <Nav />

  <main id="main" class="relative z-10">
    <!-- HERO -->
    <section class="pt-24 sm:pt-28 md:pt-32 pb-16 sm:pb-20 px-4 sm:px-6 max-w-6xl mx-auto flex flex-col md:flex-row items-start md:items-center gap-10 md:gap-12">
      <div class="md:w-2/3 reveal" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-5 text-[11px] sm:text-xs font-bold tracking-wider text-blue-400 uppercase bg-blue-500/10 rounded-full border border-blue-500/20">
          <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
          Graduating 2026 • Seeking robotics / controls / embedded roles
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-4 sm:mb-6 leading-tight">
          Bridging software and <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-500 to-cyan-400">
            the physical world.
          </span>
        </h1>

        <!-- Animated role line -->
        <div class="text-base sm:text-lg text-slate-300 mb-4">
          <Typewriter prefix="I’m a" words={TYPEWRITER_WORDS} />
        </div>

        <p class="text-base sm:text-lg text-slate-400 max-w-xl leading-relaxed mb-7 sm:mb-8">
          Hi, I’m Hishaam — a Robotics Engineering student who loves building things that move, sense, and respond.
          I work across control systems, embedded firmware, and rapid prototyping to bring ideas to life.
        </p>

        <!-- Buttons: compact grid on mobile, row on desktop -->
        <div class="grid grid-cols-2 gap-3 sm:flex sm:flex-wrap sm:gap-4">
          <a href="#projects" class="col-span-2 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-all shadow-lg shadow-blue-500/20 text-center">
            See what I’ve built
          </a>
          <a href="/assets/Hishaam_Ali_Abbasi_CV.pdf" class="px-6 py-3 glass-panel hover:bg-white/5 text-white font-medium rounded-lg transition-all text-center">
            Download CV
          </a>
          <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer" class="px-6 py-3 glass-panel hover:bg-white/5 text-white font-medium rounded-lg transition-all text-center">
            GitHub
          </a>
          <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" class="col-span-2 sm:col-auto px-6 py-3 glass-panel hover:bg-white/5 text-white font-medium rounded-lg transition-all text-center">
            LinkedIn
          </a>
        </div>

        <div class="mt-5 text-sm text-slate-500">
          <span class="text-slate-400">{SITE.location}</span> • Control • Embedded • Rapid prototyping
        </div>
      </div>

      <div class="md:w-1/3 w-full max-w-xs sm:max-w-sm md:max-w-none mx-auto md:mx-0 reveal" data-reveal>
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-500"></div>
          <div class="relative aspect-square rounded-2xl overflow-hidden glass-panel border border-white/10">
            <img src="/images/profile.jpg" alt="Hishaam Ali Abbasi" class="w-full h-full object-cover" width="640" height="640" />
          </div>
        </div>
      </div>
    </section>

    <!-- SKILLS BAND (horizontal scroll on small screens) -->
    <div class="w-full border-y border-white/5 bg-black/20 backdrop-blur-sm py-5 overflow-hidden">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex gap-x-10 gap-y-3 items-center text-slate-500 font-mono text-sm font-semibold tracking-tight overflow-x-auto whitespace-nowrap no-scrollbar">
          <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">01.</span> Control &amp; Embedded</span>
          <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">02.</span> ROS2 / Robotics</span>
          <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">03.</span> CAD / CAE</span>
          <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">04.</span> Rapid Prototyping</span>
          <span class="flex items-center gap-2 hover:text-blue-400 transition-colors"><span class="text-blue-500">05.</span> Full-Stack Web</span>
        </div>
      </div>
    </div>

    <!-- SNAPSHOTS (more images) -->
    <section class="py-14 px-4 sm:px-6 max-w-6xl mx-auto reveal" data-reveal>
      <div class="flex items-end justify-between gap-6">
        <div>
          <h2 class="text-3xl font-bold text-white">Snapshots</h2>
          <p class="text-slate-400 mt-2 max-w-2xl">A quick visual tour — prototypes, CAD, and builds. (Add your own photos/screenshots to make this feel alive.)</p>
        </div>
      </div>

      <!-- Mobile: horizontal snap. Desktop: grid -->
      <div class="mt-6 flex gap-4 overflow-x-auto snap-x snap-mandatory md:grid md:grid-cols-3 md:overflow-visible md:snap-none">
        {gallery.map((g) => (
          g.kind === 'image' ? (
            <figure class="min-w-[75%] sm:min-w-[50%] md:min-w-0 snap-start glass-panel rounded-2xl overflow-hidden border border-white/10">
              <div class="aspect-[4/3] bg-slate-900 overflow-hidden">
                <img src={g.src} alt={g.alt} loading="lazy" class="w-full h-full object-cover" width="900" height="675" />
              </div>
              <figcaption class="px-4 py-3 text-sm text-slate-300">
                <span class="text-slate-400">•</span> {g.caption}
              </figcaption>
            </figure>
          ) : (
            <div class="min-w-[75%] sm:min-w-[50%] md:min-w-0 snap-start glass-panel rounded-2xl border border-white/10 flex items-center justify-center">
              <div class="p-10 text-center">
                <div class="text-2xl text-blue-400 font-bold">+</div>
                <div class="mt-2 text-sm text-slate-300">{g.caption}</div>
                <div class="mt-1 text-xs text-slate-500">Drop a file in <span class="font-mono">/public/images/gallery</span></div>
              </div>
            </div>
          )
        ))}
      </div>

      <p class="mt-4 text-xs text-slate-500">
        Tip: add 3–6 real photos (workbench, wiring, prototypes, test rigs) and 1–2 screenshots (CAD, plots, firmware serial output).
      </p>
    </section>

    <!-- ABOUT -->
    <section id="about" class="py-16 sm:py-20 px-4 sm:px-6 max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 md:gap-12 items-start">
        <div class="reveal" data-reveal>
          <h2 class="text-3xl font-bold text-white mb-6">A hands-on approach.</h2>
          <p class="text-slate-400 mb-4 leading-relaxed">
            I learn best by building. I like the maths behind robotics (control, modelling, numerical methods),
            but I’m at my best when I can prototype, test, break things, and iterate fast.
          </p>
          <p class="text-slate-400 leading-relaxed mb-4">
            I treat my home setup as a rapid prototyping lab — from embedded firmware and sensor integration,
            to CAD and 3D printing, to shipping real products through the platforms I build.
          </p>
          <p class="text-slate-400 leading-relaxed border-l-2 border-blue-500 pl-4 italic">
            Outside engineering, I’m an <strong>Explorer Scout Leader</strong>. Running weekly sessions and expeditions has
            been the best crash course in leadership, communication, and staying calm when plans change.
          </p>
        </div>

        <div class="glass-panel p-6 rounded-xl reveal" data-reveal>
          <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider text-blue-400">Education</h3>
          <div class="space-y-4">
            <div>
              <div class="flex justify-between text-white font-medium">
                <span>BEng Robotics Engineering</span>
                <span>Graduating 2026</span>
              </div>
              <div class="text-slate-500 text-sm">Queen Mary University of London</div>
            </div>

            <div class="pt-4 border-t border-white/5">
              <div class="text-sm text-slate-400">Academic highlights:</div>
              <div class="flex flex-wrap gap-2 mt-2">
                <span class="px-2 py-1 bg-white/5 rounded text-xs text-slate-300">Numerical Methods &amp; Data Science (86%)</span>
                <span class="px-2 py-1 bg-white/5 rounded text-xs text-slate-300">Control Systems &amp; Analysis (78.9%)</span>
                <span class="px-2 py-1 bg-white/5 rounded text-xs text-slate-300">Modelling &amp; Control (75.2%)</span>
                <span class="px-2 py-1 bg-white/5 rounded text-xs text-slate-300">Design for Human Interaction (70.2%)</span>
              </div>

              <div class="mt-4 flex flex-wrap gap-3">
                <a href="/assets/HEAR_Hishaam_Ali_Abbasi.pdf" class="px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-xs font-medium text-white transition-all">
                  Download HEAR
                </a>
                <a href="/assets/Hishaam_Ali_Abbasi_CV.pdf" class="px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-xs font-medium text-white transition-all">
                  Download CV
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SOCIAL / MEDIA -->
    <section class="pb-20 px-4 sm:px-6 max-w-6xl mx-auto">
      <div class="glass-panel rounded-2xl p-6 sm:p-8 reveal" data-reveal>
        <div class="flex flex-col lg:flex-row gap-8 items-start">
          <div class="lg:w-1/2">
            <h2 class="text-2xl sm:text-3xl font-bold text-white">More than a CV</h2>
            <p class="text-slate-400 mt-2 leading-relaxed">
              If you want the real behind-the-scenes — builds, demos, and progress — my YouTube has project videos, and my Instagram is kept clean for professional viewing.
            </p>
            <div class="mt-4 flex flex-wrap gap-3">
              <a href={SOCIAL.youtube} target="_blank" rel="noopener noreferrer" class="px-5 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-sm font-semibold text-white transition">
                YouTube ↗
              </a>
              <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" class="px-5 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-sm font-semibold text-white transition">
                Instagram ↗
              </a>
            </div>
            <p class="mt-3 text-xs text-slate-500">
              Update your handles in <span class="font-mono">src/site-config.ts</span>.
            </p>
          </div>

          <div class="lg:w-1/2 w-full">
            {yt.length > 0 ? (
              <div class="grid sm:grid-cols-2 gap-4">
                {yt.slice(0, 4).map((v) => (
                  <a
                    class="glass-panel rounded-2xl overflow-hidden border border-white/10 hover:border-blue-500/40 hover:bg-white/5 transition group"
                    href={`https://www.youtube.com/watch?v=${v.id}`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <div class="aspect-[16/9] bg-slate-900 overflow-hidden">
                      <img
                        src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`}
                        alt={v.title}
                        loading="lazy"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                        width="1280"
                        height="720"
                      />
                    </div>
                    <div class="p-4">
                      <div class="text-sm font-semibold text-white">{v.title}</div>
                      <div class="text-xs text-slate-500 mt-1">Watch on YouTube ↗</div>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="glass-panel rounded-2xl border border-white/10 p-6">
                <div class="text-white font-semibold">Feature your best demos here</div>
                <p class="text-slate-400 text-sm mt-2">
                  Add 2–4 video IDs to <span class="font-mono">FEATURED_YOUTUBE_VIDEOS</span> in <span class="font-mono">src/site-config.ts</span>.
                </p>
                <p class="text-slate-500 text-xs mt-2">Example: the ID in <span class="font-mono">watch?v=VIDEO_ID</span>.</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="py-20 sm:py-24 px-4 sm:px-6 max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-10 sm:mb-12 reveal" data-reveal>
        <div>
          <h2 class="text-4xl font-bold text-white mb-2">Things I’ve built</h2>
          <p class="text-slate-400">Case studies with design decisions, architecture, and outcomes.</p>
        </div>
        <a class="hidden md:inline-flex text-sm text-blue-400 hover:underline" href="/projects">View all case studies →</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured.map((p) => (
          <ProjectCard
            href={`/projects/${p.slug}`}
            title={p.data.title}
            subtitle={p.data.subtitle}
            image={p.data.heroImage}
            tags={p.data.tags}
            featured={p.data.featured}
          />
        ))}

        <!-- External: Bones of Steel -->
        <a href="https://www.bones-of-steel.com/" target="_blank" rel="noopener noreferrer"
           class="lg:col-span-2 glass-panel rounded-2xl overflow-hidden hover:border-blue-500/50 hover:bg-white/5 transition-all duration-300 group cursor-pointer block reveal" data-reveal>
          <div class="flex flex-col md:flex-row h-full">
            <div class="md:w-2/5 bg-slate-900 relative p-6 flex items-center justify-center border-r border-white/5">
              <div class="text-center">
                <h3 class="text-3xl font-bold text-white">Bones of Steel</h3>
                <p class="text-sm text-blue-400 mt-2 group-hover:underline">bones-of-steel.com ↗</p>
              </div>
            </div>
            <div class="md:w-3/5 p-8 flex flex-col justify-center">
              <h3 class="text-2xl font-bold text-white mb-2">E-commerce + product fulfilment</h3>
              <p class="text-slate-400 mb-4 leading-relaxed">
                I built and launched a full-stack platform and handle end-to-end operations — from web UX and payments to 3D printing, packaging, and shipping.
              </p>
              <div class="flex gap-2 flex-wrap font-mono text-xs text-blue-300">
                <span class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full">Web Dev</span>
                <span class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full">Operations</span>
                <span class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full">3D Printing</span>
              </div>
            </div>
          </div>
        </a>

        <!-- External: Made By Layers -->
        <a href="https://www.madebylayers.co.uk/" target="_blank" rel="noopener noreferrer"
           class="glass-panel rounded-2xl overflow-hidden hover:border-blue-500/50 hover:bg-white/5 transition-all duration-300 group flex flex-col cursor-pointer block reveal" data-reveal>
          <div class="h-32 bg-slate-900 relative overflow-hidden flex items-center justify-center border-b border-white/5">
            <h3 class="text-xl font-bold text-white">Made By Layers</h3>
          </div>
          <div class="p-6 flex-1 flex flex-col">
            <h3 class="text-xl font-bold text-white mb-2">Additive manufacturing services</h3>
            <p class="text-slate-400 text-sm mb-4 flex-1">
              A platform I built to showcase additive manufacturing work and offer local CAD &amp; 3D printing services.
            </p>
            <p class="text-sm text-blue-400 mb-4 group-hover:underline">madebylayers.co.uk ↗</p>
            <div class="flex gap-2 flex-wrap font-mono text-xs text-blue-300 mt-auto">
              <span class="px-2 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full">Service Platform</span>
            </div>
          </div>
        </a>
      </div>

      <div class="mt-10 md:hidden">
        <a class="text-sm text-blue-400 hover:underline" href="/projects">View all case studies →</a>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="py-20 px-4 sm:px-6 max-w-6xl mx-auto border-t border-white/5">
      <h2 class="text-3xl font-bold text-white mb-12 reveal" data-reveal>Experience</h2>

      <div class="space-y-8">
        <div class="glass-panel p-8 rounded-2xl hover:bg-white/5 transition-colors reveal" data-reveal>
          <div class="flex flex-col md:flex-row gap-6 md:gap-12">
            <div class="md:w-1/4">
              <div class="text-blue-400 font-mono text-sm mb-1 font-bold">Aug 2025</div>
              <div class="text-white text-lg font-bold">Alvis Robotics</div>
              <div class="text-slate-500 text-sm">Birmingham, UK</div>
            </div>
            <div class="md:w-3/4">
              <h3 class="text-xl font-bold text-white mb-2">Engineering Design &amp; Research Intern (EOD Systems)</h3>
              <p class="text-slate-400 leading-relaxed mb-4">
                Shadowed R&amp;D work on bomb disposal robots: firmware debugging, diagnosing physical failure points, and helping overhaul legacy platforms.
                Built confidence working on systems where reliability matters.
              </p>
              <div class="flex flex-wrap gap-2 text-xs font-mono text-blue-200">
                <span class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full">Embedded Debugging</span>
                <span class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full">R&amp;D Support</span>
                <span class="px-3 py-1 bg-blue-500/10 border border-blue-500/20 rounded-full">Hardware Reliability</span>
              </div>
            </div>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-2xl hover:bg-white/5 transition-colors reveal" data-reveal>
          <div class="flex flex-col md:flex-row gap-6 md:gap-12">
            <div class="md:w-1/4">
              <div class="text-blue-400 font-mono text-sm mb-1 font-bold">Jul–Aug 2024</div>
              <div class="text-white text-lg font-bold">HSBC</div>
              <div class="text-slate-500 text-sm">London, UK</div>
            </div>
            <div class="md:w-3/4">
              <h3 class="text-xl font-bold text-white mb-2">Spring Insight Programme (Quant Stream)</h3>
              <p class="text-slate-400 leading-relaxed">
                Explored modelling, data analysis workflows, and how large institutions handle noisy datasets.
              </p>
            </div>
          </div>
        </div>

        <div class="glass-panel p-8 rounded-2xl hover:bg-white/5 transition-colors reveal" data-reveal>
          <div class="flex flex-col md:flex-row gap-6 md:gap-12">
            <div class="md:w-1/4">
              <div class="text-blue-400 font-mono text-sm mb-1 font-bold">2020–2021</div>
              <div class="text-white text-lg font-bold">AT Medics</div>
              <div class="text-slate-500 text-sm">London, UK</div>
            </div>
            <div class="md:w-3/4">
              <h3 class="text-xl font-bold text-white mb-2">Clinical Data Admin &amp; Front of House (COVID Clinic)</h3>
              <p class="text-slate-400 leading-relaxed">
                Worked with high-volume clinical data and patient-facing processes — strong attention to detail, calm communication, and system discipline.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Subtle scroll-reveal to make the page feel more "alive" -->
  <script>
    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els = Array.from(document.querySelectorAll('[data-reveal]'));

    // Default: reveal immediately if reduced motion or no IO support.
    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('reveal-in'));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('reveal-in');
              io.unobserve(e.target);
            }
          });
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.12 }
      );

      els.forEach((el) => io.observe(el));
    }
  </script>
</BaseLayout>
