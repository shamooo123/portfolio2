---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout title="404 | Hishaam Ali Abbasi" description="Page not found." canonicalPath="/404/" noindex={true}>
  <div class="fixed inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(56,189,248,0.04),transparent_55%)]"></div>
  </div>

  <Nav />
  <main class="relative z-10 pt-28 pb-10 px-6 max-w-4xl mx-auto">
    <h1 class="text-4xl font-extrabold text-white">404</h1>
    <p class="mt-3 text-slate-400">That page doesn’t exist.</p>
    <a href="/" class="inline-block mt-6 text-blue-400 hover:underline">Go home →</a>
  </main>
  <Footer />
</BaseLayout>
