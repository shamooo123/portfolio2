---
import TagPill from "./TagPill.astro";

const { href, title, subtitle, image, tags = [], featured = false } = Astro.props;
const height = featured ? "h-64" : "h-48";
const padding = featured ? "p-8" : "p-6";
const titleSize = featured ? "text-2xl" : "text-xl";
---
<a href={href} class={"glass-panel rounded-2xl overflow-hidden hover:border-blue-500/40 hover:bg-white/5 transition-all duration-300 group block " + (featured ? "md:col-span-2" : "")}>
  <div class={`${height} bg-slate-900 relative overflow-hidden`}>
    {image ? (
      <img src={image} alt={title} loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-85 group-hover:opacity-100" />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-slate-500">No image</div>
    )}
  </div>
  <div class={padding}>
    <h3 class={`${titleSize} font-bold text-white mb-2`}>{title}</h3>
    {subtitle && <p class="text-slate-400 text-sm leading-relaxed mb-4">{subtitle}</p>}
    <div class="flex gap-2 flex-wrap">
      {tags.slice(0, featured ? 6 : 4).map((t) => <TagPill label={t} />)}
    </div>
  </div>
</a>
