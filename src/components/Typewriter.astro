---
const {
  prefix = "I’m a",
  words = ["Robotics Engineer", "Embedded Developer", "Rapid Prototyper"],
  forceAnimate = false,
  class: className = "",
} = Astro.props;

const wordsJson = JSON.stringify(words);
const srText = `${prefix} ${words.join(", ")}.`;
---

<div
  class={`typewriter ${className}`}
  data-typewriter
  data-prefix={prefix}
  data-words={wordsJson}
  data-force={forceAnimate ? "1" : "0"}
>
  <span class="typewriter__prefix">{prefix}&nbsp;</span>
  <span class="typewriter__word" aria-hidden="true"></span>
  <span class="typewriter__caret" aria-hidden="true"></span>

  <span class="sr-only">{srText}</span>
</div>

<script is:inline>
  const boot = () => {
    document.querySelectorAll("[data-typewriter]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;

      const target = root.querySelector(".typewriter__word");
      if (!target) return;

      let words = [];
      try {
        words = JSON.parse(root.getAttribute("data-words") || "[]");
      } catch {
        words = [];
      }
      if (!Array.isArray(words) || words.length === 0) return;

      const force = root.getAttribute("data-force") === "1";
      const reduceMotion =
        !force &&
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reduceMotion) {
        target.textContent = String(words[0]);
        return;
      }

      let wordIndex = 0;
      let charIndex = 0;
      let deleting = false;

      const TYPE_SPEED = 55;
      const DELETE_SPEED = 35;
      const HOLD_MS = 900;
      const BETWEEN_MS = 200;

      const tick = () => {
        const current = String(words[wordIndex % words.length]);

        if (!deleting) {
          charIndex++;
          target.textContent = current.slice(0, charIndex);
          if (charIndex >= current.length) {
            deleting = true;
            setTimeout(tick, HOLD_MS);
            return;
          }
          setTimeout(tick, TYPE_SPEED);
        } else {
          charIndex--;
          target.textContent = current.slice(0, Math.max(0, charIndex));
          if (charIndex <= 0) {
            deleting = false;
            wordIndex++;
            setTimeout(tick, BETWEEN_MS);
            return;
          }
          setTimeout(tick, DELETE_SPEED);
        }
      };

      setTimeout(tick, 150);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
</script>
