---
const {
  prefix = "I’m a",
  words = ["Robotics Engineer", "Embedded Developer", "Rapid Prototyper"],
  forceAnimate = true,
  class: className = "",
} = Astro.props;

const wordsJson = JSON.stringify(words);
const srText = `${prefix} ${words.join(", ")}.`;
---

<div
  class={`typewriter ${className}`}
  data-typewriter
  data-prefix={prefix}
  data-words={wordsJson}
  data-force={forceAnimate ? "1" : "0"}
>
  <span class="typewriter__prefix">{prefix}&nbsp;</span>

  <!-- Leading cursor underscore -->
  <span class="typewriter__cursor" aria-hidden="true" data-cursor>_</span>

  <!-- Typed text -->
  <span class="typewriter__word" aria-hidden="true" data-word></span>

  <span class="sr-only">{srText}</span>
</div>

<script is:inline>
  const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

  const boot = async () => {
    const roots = document.querySelectorAll("[data-typewriter]");
    for (const root of roots) {
      if (!(root instanceof HTMLElement)) continue;

      const cursor = root.querySelector("[data-cursor]");
      const wordEl = root.querySelector("[data-word]");
      if (!(cursor instanceof HTMLElement) || !(wordEl instanceof HTMLElement)) continue;

      let words = [];
      try {
        words = JSON.parse(root.getAttribute("data-words") || "[]");
      } catch {
        words = [];
      }
      if (!Array.isArray(words) || words.length === 0) continue;

      const force = root.getAttribute("data-force") === "1";
      const reduceMotion =
        !force &&
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reduceMotion) {
        wordEl.textContent = String(words[0]);
        cursor.classList.add("typewriter__cursor--idle");
        continue;
      }

      const TYPE_SPEED = 55;
      const DELETE_SPEED = 35;
      const HOLD_MS = 600;

      const blinkCursor = async (times = 2) => {
        cursor.classList.add("typewriter__cursor--blink");
        // each blink cycle is 350ms (see CSS); blink twice means ~700ms.
        await sleep(times * 700);
        cursor.classList.remove("typewriter__cursor--blink");
      };

      let wordIndex = 0;

      while (true) {
        const current = String(words[wordIndex % words.length]);

        // TYPE
        for (let i = 1; i <= current.length; i++) {
          wordEl.textContent = current.slice(0, i);
          await sleep(TYPE_SPEED);
        }

        // HOLD + blink underscore twice
        await sleep(HOLD_MS);
        await blinkCursor(2);

        // DELETE
        for (let i = current.length - 1; i >= 0; i--) {
          wordEl.textContent = current.slice(0, i);
          await sleep(DELETE_SPEED);
        }

        wordIndex++;
        await sleep(180);
      }
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
</script>
