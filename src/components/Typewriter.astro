---
const {
  prefix = "I’m a",
  words = ["Robotics Engineer", "Embedded Developer", "Rapid Prototyper"],
  forceAnimate = true,
  class: className = "",
} = Astro.props;

const wordsJson = JSON.stringify(words);
const srText = `${prefix} ${words.join(", ")}.`;
---

<div
  class={`typewriter ${className}`}
  data-typewriter
  data-prefix={prefix}
  data-words={wordsJson}
  data-force={forceAnimate ? "1" : "0"}
>
  <span class="typewriter__prefix">{prefix}&nbsp;</span>

  <!-- Leading underscore cursor -->
  <span class="typewriter__cursor" aria-hidden="true" data-tw-cursor>_</span>

  <!-- The typed text -->
  <span class="typewriter__word" aria-hidden="true" data-tw-word></span>

  <span class="sr-only">{srText}</span>
</div>

<script is:inline>
  const boot = () => {
    document.querySelectorAll("[data-typewriter]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;

      const cursor = root.querySelector("[data-tw-cursor]");
      const wordEl = root.querySelector("[data-tw-word]");
      if (!cursor || !wordEl) return;

      let words = [];
      try {
        words = JSON.parse(root.getAttribute("data-words") || "[]");
      } catch {
        words = [];
      }
      if (!Array.isArray(words) || words.length === 0) return;

      const force = root.getAttribute("data-force") === "1";
      const reduceMotion =
        !force &&
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // If reduced motion, show a stable first word.
      if (reduceMotion) {
        wordEl.textContent = String(words[0]);
        cursor.classList.add("tw-cursor-blink");
        return;
      }

      // Timing
      const TYPE_SPEED = 55;
      const DELETE_SPEED = 35;
      const HOLD_MS = 700;

      // Blink underscore a couple times after full word typed
      const BLINKS_AFTER_FULL = 2;      // "a couple"
      const BLINK_MS = 260;

      // State
      let wordIndex = 0;
      let charIndex = 0;
      let deleting = false;

      const setCursorBlink = (on) => {
        cursor.classList.toggle("tw-cursor-blink", on);
      };

      const blinkCursorTimes = async (count) => {
        setCursorBlink(false); // we'll do manual blink
        for (let i = 0; i < count; i++) {
          cursor.classList.add("tw-cursor-hidden");
          await new Promise((r) => setTimeout(r, BLINK_MS));
          cursor.classList.remove("tw-cursor-hidden");
          await new Promise((r) => setTimeout(r, BLINK_MS));
        }
      };

      const tick = async () => {
        const current = String(words[wordIndex % words.length]);

        if (!deleting) {
          setCursorBlink(false);
          charIndex++;
          wordEl.textContent = current.slice(0, charIndex);

          if (charIndex >= current.length) {
            // finished typing -> blink underscore a couple times -> hold -> start deleting
            await blinkCursorTimes(BLINKS_AFTER_FULL);
            setCursorBlink(true);
            setTimeout(() => {
              setCursorBlink(false);
              deleting = true;
              tick();
            }, HOLD_MS);
            return;
          }

          setTimeout(tick, TYPE_SPEED);
        } else {
          setCursorBlink(false);
          charIndex--;
          wordEl.textContent = current.slice(0, Math.max(0, charIndex));

          if (charIndex <= 0) {
            deleting = false;
            wordIndex++;
            setTimeout(tick, 180);
            return;
          }

          setTimeout(tick, DELETE_SPEED);
        }
      };

      // Start
      cursor.classList.remove("tw-cursor-hidden");
      setCursorBlink(false);
      setTimeout(tick, 150);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
</script>
