---
import { SOCIAL, SITE } from "../site-config";
---

<footer id="contact" class="py-20 bg-black/40 border-t border-white/5 mt-12 relative z-10">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-3xl font-bold text-white mb-6">Let’s build something.</h2>
    <p class="text-slate-400 mb-8 max-w-lg mx-auto">
      I’m open to chatting about robotics, control, embedded systems, 3D printing, and exciting R&amp;D opportunities.
    </p>

    <div class="flex justify-center flex-wrap gap-3">
      <a href={`mailto:${SITE.email}`} class="flex items-center gap-2 px-5 py-3 bg-white/5 rounded-lg text-white hover:text-blue-400 hover:bg-white/10 transition-all border border-white/10">
        <span aria-hidden="true">✉</span> Email
      </a>
      <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-3 bg-white/5 rounded-lg text-white hover:text-blue-400 hover:bg-white/10 transition-all border border-white/10">
        <span aria-hidden="true">in</span> LinkedIn
      </a>
      <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-3 bg-white/5 rounded-lg text-white hover:text-blue-400 hover:bg-white/10 transition-all border border-white/10">
        <span aria-hidden="true">⌂</span> GitHub
      </a>
      <a href={SOCIAL.youtube} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-3 bg-white/5 rounded-lg text-white hover:text-blue-400 hover:bg-white/10 transition-all border border-white/10">
        <span aria-hidden="true">▶</span> YouTube
      </a>
      <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-3 bg-white/5 rounded-lg text-white hover:text-blue-400 hover:bg-white/10 transition-all border border-white/10">
        <span aria-hidden="true">◎</span> Instagram
      </a>
    </div>

    <p class="mt-10 text-slate-500 text-xs">
      <a class="hover:text-blue-400 underline-offset-4 hover:underline" href="/assets/HEAR_Hishaam_Ali_Abbasi.pdf">Download HEAR</a>
      <span class="mx-2">•</span>
      <a class="hover:text-blue-400 underline-offset-4 hover:underline" href="/assets/Hishaam_Ali_Abbasi_CV.pdf">Download CV</a>
    </p>

    <p class="mt-12 text-slate-600 text-xs font-mono">© 2026 {SITE.name}. Built by hand.</p>
  </div>
</footer>
