---
import { SOCIAL, SITE } from "../site-config";

const nav = [
  { href: "/#about", label: "About" },
  { href: "/#projects", label: "Projects" },
  { href: "/#experience", label: "Experience" },
  { href: "/projects", label: "Case studies" },
];

// Simple Icons SVG paths (brand glyphs). CC0.
const icons = {
  github: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.084-.729.084-.729 1.205.084 1.84 1.236 1.84 1.236 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.468-2.381 1.235-3.221-.123-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.241 2.873.118 3.176.77.84 1.233 1.911 1.233 3.221 0 4.61-2.807 5.625-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .322.218.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM6.814 20.452H3.86V9h2.954v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.727v20.545C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.273V1.727C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  youtube: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186 31.247 31.247 0 0 0 0 12a31.247 31.247 0 0 0 .502 5.814 3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136A31.247 31.247 0 0 0 24 12a31.247 31.247 0 0 0-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2zm9 2h-9A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2.1a2.9 2.9 0 1 0 0 5.8 2.9 2.9 0 0 0 0-5.8zM18 6.3a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>`,
};
---

<nav class="fixed top-0 w-full z-50 glass-panel border-b-0 border-b-white/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight text-white">
      H.A. <span class="text-blue-500">Abbasi</span>
    </a>

    <div class="hidden md:flex gap-8 text-sm font-medium text-slate-400">
      {nav.map((item) => (
        <a href={item.href} class="hover:text-blue-400 transition-colors">{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <div class="hidden md:flex items-center gap-1">
        <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer"
           class="p-2 rounded-lg text-slate-300 hover:text-blue-400 hover:bg-white/5 transition" aria-label="GitHub">
          <span class="w-5 h-5 block" set:html={icons.github}></span>
        </a>
        <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer"
           class="p-2 rounded-lg text-slate-300 hover:text-blue-400 hover:bg-white/5 transition" aria-label="LinkedIn">
          <span class="w-5 h-5 block" set:html={icons.linkedin}></span>
        </a>
        <a href={SOCIAL.youtube} target="_blank" rel="noopener noreferrer"
           class="p-2 rounded-lg text-slate-300 hover:text-blue-400 hover:bg-white/5 transition" aria-label="YouTube">
          <span class="w-5 h-5 block" set:html={icons.youtube}></span>
        </a>
        <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer"
           class="p-2 rounded-lg text-slate-300 hover:text-blue-400 hover:bg-white/5 transition" aria-label="Instagram">
          <span class="w-5 h-5 block" set:html={icons.instagram}></span>
        </a>
      </div>

      <a href="/assets/Hishaam_Ali_Abbasi_CV.pdf"
         class="hidden sm:inline-flex px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs font-medium text-white transition-all">
        Download CV
      </a>

      <a href={`mailto:${SITE.email}`}
         class="hidden sm:inline-flex px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded-full text-xs font-semibold text-white transition-all">
        Get in touch
      </a>

      <button id="navToggle"
        class="md:hidden inline-flex items-center justify-center p-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white"
        aria-label="Open menu" aria-expanded="false" aria-controls="mobileNav" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
          <path d="M4 6h16" />
          <path d="M4 12h16" />
          <path d="M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobileNav" class="md:hidden hidden border-t border-white/5 bg-slate-950/70 backdrop-blur">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4">
      <div class="grid gap-2">
        {nav.map((item) => (
          <a href={item.href} class="px-3 py-2 rounded-lg text-slate-200 hover:bg-white/5 transition" data-mobile-nav-link>
            {item.label}
          </a>
        ))}
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-sm text-white transition">
          <span class="w-4 h-4 block" set:html={icons.github}></span> GitHub
        </a>
        <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-sm text-white transition">
          <span class="w-4 h-4 block" set:html={icons.linkedin}></span> LinkedIn
        </a>
        <a href={SOCIAL.youtube} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-sm text-white transition">
          <span class="w-4 h-4 block" set:html={icons.youtube}></span> YouTube
        </a>
        <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-sm text-white transition">
          <span class="w-4 h-4 block" set:html={icons.instagram}></span> Instagram
        </a>
      </div>

      <div class="mt-4 flex flex-col sm:flex-row gap-2">
        <a href="/assets/Hishaam_Ali_Abbasi_CV.pdf"
           class="inline-flex justify-center px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-sm font-medium text-white transition">
          Download CV
        </a>
        <a href={`mailto:${SITE.email}`}
           class="inline-flex justify-center px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded-lg text-sm font-semibold text-white transition">
          Get in touch
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('navToggle');
  const panel = document.getElementById('mobileNav');

  const closeMenu = () => {
    if (!btn || !panel) return;
    panel.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');
  };

  const toggleMenu = () => {
    if (!btn || !panel) return;
    const isHidden = panel.classList.contains('hidden');
    if (isHidden) {
      panel.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
    } else {
      closeMenu();
    }
  };

  btn?.addEventListener('click', toggleMenu);
  panel?.querySelectorAll('[data-mobile-nav-link]').forEach((a) => a.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
  document.addEventListener('click', (e) => {
    if (!panel || !btn) return;
    const t = e.target;
    if (!(t instanceof Node)) return;
    if (!panel.contains(t) && !btn.contains(t)) closeMenu();
  });
</script>
