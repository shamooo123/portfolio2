---
const nav = [
  { href: "/#about", label: "About" },
  { href: "/#projects", label: "Projects" },
  { href: "/#experience", label: "Experience" },
  { href: "/projects", label: "Case studies" },
];
---
<nav class="fixed top-0 w-full z-50 glass-panel border-b-0 border-b-white/5">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight text-white">
      H.A. <span class="text-blue-500">Abbasi</span>
    </a>

    <div class="hidden md:flex gap-8 text-sm font-medium text-slate-400">
      {nav.map((item) => (
        <a href={item.href} class="hover:text-blue-400 transition-colors">{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href="/assets/Hishaam_Ali_Abbasi_CV.pdf" class="hidden sm:inline-flex px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs font-medium text-white transition-all">
        Download CV
      </a>
      <a href="mailto:hishaamabbasi@gmail.com" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded-full text-xs font-semibold text-white transition-all">
        Get in touch
      </a>
    </div>
  </div>
</nav>
